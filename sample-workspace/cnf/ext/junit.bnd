# JUnit Configuration
#
# This file defines JUnit versions and test dependencies.

# JUnit versions
junit4.version: 4.13.2
junit.jupiter.version: 5.10.2
junit.platform.version: 1.10.2

# JUnit 4 for OSGi testing
junit: \
    org.apache.servicemix.bundles.junit;version='[4.12,5)'

# JUnit 5 / JUnit Platform for modern testing
junit5: \
    junit-platform-commons,\
    junit-platform-engine,\
    junit-platform-launcher,\
    junit-jupiter-api,\
    junit-jupiter-engine

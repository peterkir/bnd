# Export / Executable JAR Configuration
#
# This bndrun file demonstrates creating an executable JAR.
#
# Usage:
#   bnd export export.bndrun                    # Export to executable JAR
#   bnd export -o myapp.jar export.bndrun       # Export with custom name
#   bnd export -v export.bndrun                 # Export with verbose output
#
# The exported JAR can be run with:
#   java -jar generated/export.jar
#
# Export options:
#   -exporttype: Controls what type of export (default: bnd.executablejar)
#   -executable: Configure executable JAR options

Bundle-Version: 1.0.0
Bundle-Name: Export Example
Bundle-SymbolicName: sample.export

# Framework configuration
-runfw: org.apache.felix.framework;version='[7.0.5,8)'
-runee: JavaSE-17

# System capabilities for resolution
-runsystemcapabilities: ${native_capability}
-resolve.effective: active

# Requirements
-runrequires: \
    osgi.identity;filter:='(osgi.identity=sample.impl)',\
    osgi.identity;filter:='(osgi.identity=org.apache.felix.gogo.shell)',\
    osgi.identity;filter:='(osgi.identity=org.apache.felix.gogo.command)'

# Run bundles
-runbundles: \
    sample.api;version=snapshot,\
    sample.impl;version=snapshot,\
    org.apache.felix.scr;version='[2.2.10,3)',\
    org.apache.felix.gogo.runtime;version='[1.1.6,2)',\
    org.apache.felix.gogo.shell;version='[1.1.4,2)',\
    org.apache.felix.gogo.command;version='[1.1.2,2)'

# Export configuration
# bnd.executablejar - creates self-contained executable JAR
# bnd.runbundles - exports just the run bundles
-exporttype: \
    bnd.executablejar;name=sample-app,\
    bnd.runbundles;name=sample-bundles

# Executable JAR options
# rejar=STORE - Use STORE compression for faster startup
# strip=OSGI-OPT/* - Remove optional resources to reduce size
-executable: rejar=STORE, strip=OSGI-OPT/*

# Runtime properties
-runproperties: \
    osgi.console=,\
    osgi.console.enable.builtin=false

# Enable tracing
-runtrace: true

{
  "name": "vscode-bnd",
  "displayName": "Bnd and Bndrun Support",
  "description": "Language support for bnd and bndrun files — syntax highlighting, IntelliSense completions and hover docs via Language Server Protocol",
  "version": "0.2.0",
  "publisher": "bndtools",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:bnd"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "bnd",
        "aliases": [
          "Bnd",
          "bnd"
        ],
        "extensions": [
          ".bnd",
          ".bndrun"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bnd",
        "scopeName": "source.bnd",
        "path": "./syntaxes/bnd.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile:all",
    "compile": "tsc -p ./tsconfig.json",
    "compile:server": "tsc -p ./server/tsconfig.json",
    "compile:all": "npm run compile && npm run compile:server",
    "watch": "tsc -watch -p ./",
    "watch:server": "tsc -watch -p ./server/",
    "package": "vsce package --allow-missing-repository --no-git-tag-version"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.0.0"
  }
}
